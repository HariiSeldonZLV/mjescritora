import { ApplicationConfig } from '@angular/core';
import { provideRouter } from '@angular/router';
import { routes } from './app.routes';
import { initializeApp, provideFirebaseApp } from '@angular/fire/app';
import { getAuth, provideAuth } from '@angular/fire/auth';
import { getFirestore, provideFirestore } from '@angular/fire/firestore';

const firebaseConfig = {
  apiKey: "AIzaSyCzEzpd6D8abEqIV0PTFxHsGdBcAt_Y6u8",
  authDomain: "mjescritora.firebaseapp.com",
  projectId: "mjescritora",
  storageBucket: "mjescritora.firebasestorage.app",
  messagingSenderId: "627348994550",
  appId: "1:627348994550:web:22fe5e5317ced8e3482fd7"
};

export const appConfig: ApplicationConfig = {
  providers: [
    // El orden importa: FirebaseApp PRIMERO
    provideFirebaseApp(() => initializeApp(firebaseConfig)),
    provideAuth(() => getAuth()),
    provideFirestore(() => getFirestore()),
    provideRouter(routes)
  ]
};
